---
import { getCollection } from "astro:content";

import "../styles/global.css";
import "../config/variables.css";
import data from "../config/site.json";

import Meta from "../components/Meta.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Footer from "../components/Footer.astro";
import Option from "../components/Option.astro";

function checkOrdering(a: any, b: any, ascendingOrder: boolean) {
    if (ascendingOrder) {
        return b.data.publishedOn.valueOf() - a.data.publishedOn.valueOf();
    } else {
        return a.data.publishedOn.valueOf() - b.data.publishedOn.valueOf();
    }
}

const releases = (await getCollection("releases")).sort(
    (a, b) => checkOrdering(a, b, data.config.releases.ascendingOrder),
);

const { title, date, notes, audio } = Astro.props;
---

<html lang="en">
    <Meta title={title} />
    <script is:inline>
        function handleRedirect() {
            const selectedValue = document.getElementById("releaseIndex").value;
            if (selectedValue) {
                window.location.href = selectedValue;
            }
        }
    </script>
    <body class="bg-background px-[25rem] py-[1rem]">
        {
            audio ? (
                <div class="ml-[25%] mr-[25%] mt-10 mb-5">
                    <audio class="w-[100%]" controls loop>
                        <source src={audio} />
                    </audio>
                </div>
            ) : null
        }
        <div class="text-center mb-20">
            <h1>{title}</h1>
            <h3 class="text-subtext">
                Published on <FormattedDate date={date} />
            </h3>
            <select class="mt-5 border border-white-100 rounded-xs" name=`-- ${data.config.releases.navBarName} --` id="releaseIndex" onchange="handleRedirect()">
                <option value="#">All {data.config.releases.navBarName}</option>
                {
                    releases.map((release) => (
                        <Option 
                            id={release.id} 
                            title={release.data.title}
                        />
                    ))
                }
            </select>
        </div>
        <div>
            <div class="my-10">
                {
                    notes ? (
                        <hr />
                        <div class="my-5">
                            <h2><b>Notes</b></h2>
                            <br>
                            <h3>{notes}</h3>
                        </div>
                        <hr />
                    ) : null
                }
            </div>
            <slot />
        </div>
        <Footer />
    </body>
</html>
